{
  "name": "mpesa-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "start:lan": "expo start --lan",
    "start:dev-client": "expo start --dev-client --localhost",
    "usb:reverse": "adb reverse tcp:8081 tcp:8081 && adb reverse tcp:8000 tcp:8000",
    "start:usb": "npm run usb:reverse && npm run start:dev-client",
    "start:tunnel": "expo start --tunnel -c",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "postinstall": "node scripts/patch-react-native-gradle-plugin.js"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.6",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "^55.0.4",
    "expo-secure-store": "~55.0.8",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.10",
    "typescript": "^5.3.3"
  }
}
